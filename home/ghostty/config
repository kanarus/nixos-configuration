# hide titlebar
gtk-titlebar = false
window-decoration = none

window-padding-x = 3
window-padding-y = 2

window-save-state = never
resize-overlay = never
link-url = false
scrollbar = never

shell-integration = none
confirm-close-surface = false

background = "#1a1a1a"
foreground = "#e2eaff"

cursor-style = bar

font-size = 15
font-family = "UDEV Gothic 35NF"
