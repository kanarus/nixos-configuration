# hide titlebar
gtk-titlebar = false
window-decoration = none

window-padding-x = 4
window-padding-y = 4

window-save-state = never
resize-overlay = never
link-url = false

shell-integration = none
confirm-close-surface = false

background = "#1a1a1a"

cursor-style = bar

font-size = 14
font-family = "UDEV Gothic 35NF"
